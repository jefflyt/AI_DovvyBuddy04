{
  "name": "dovvybuddy",
  "version": "0.1.0",
  "private": true,
  "description": "DovvyBuddy - AI diving assistant for certification guidance and trip planning",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "start": "pnpm --dir apps/web start",
    "agent:preflight": "bash tooling/scripts/agent-preflight.sh",
    "agent:scan": "bash tooling/scripts/agent-scan.sh",
    "test": "vitest run --config tooling/config/vitest.config.ts",
    "test:watch": "vitest --config tooling/config/vitest.config.ts",
    "test:integration": "cd apps/api && ../../.venv/bin/python -m pytest tests/integration -q",
    "test:e2e": "playwright test --config tooling/config/playwright.config.ts",
    "test:e2e:headed": "playwright test --config tooling/config/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config tooling/config/playwright.config.ts --ui",
    "lint": "pnpm --dir apps/web lint",
    "lint:fix": "pnpm --dir apps/web lint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm --dir apps/web typecheck",
    "content:validate": "cd apps/api && python3 -m scripts.validate_content",
    "content:ingest": "cd apps/api && python3 -m scripts.ingest_content",
    "content:ingest:incremental": "cd apps/api && python3 -m scripts.ingest_content",
    "content:clear": "cd apps/api && python3 -m scripts.clear_embeddings",
    "content:review": "tsx tooling/scripts/review-content.ts",
    "benchmark:rag": "cd apps/api && python3 -m scripts.benchmark_rag",
    "benchmark:rag:gate": "cd apps/api && python3 -m scripts.benchmark_rag --min-mean-accuracy 0.6 --max-error-rate 0.2 --max-p95-latency-ms 2500",
    "quality:grounding": "cd apps/api && python3 -m scripts.evaluate_grounding --cases tests/fixtures/grounding_eval_cases.json --min-citation-rate 0.5 --max-unsupported-claim-rate 0.5"
  },
  "dependencies": {
    "@sentry/nextjs": "^8.40.0",
    "@vercel/analytics": "^1.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.563.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.12.7",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
